PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/reel_stock_management
JWT_SECRET=replace_with_a_strong_secret
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin@123
DEFAULT_USERNAME=user
DEFAULT_USER_EMAIL=user@example.com
DEFAULT_USER_PASSWORD=user@123

# Optional: only if you must override the bind address (default 0.0.0.0 — required on Render)
# LISTEN_HOST=127.0.0.1

# --- Render / Railway / VPS (no backend/.env file on the server) ---
# In the host "Environment" / "Variables" UI, set at least:
#   MONGO_URI   = your MongoDB Atlas SRV string (same as local)
#   JWT_SECRET  = long random string (not the dev default)
# Optional: ADMIN_*, DEFAULT_* to override seed defaults
# Do not set PORT on Render — the platform sets process.env.PORT

# --- Hostinger (no build/start command fields) ---
# Entry file: backend/start.js
# Env: NODE_ENV=production, MONGO_URI, JWT_SECRET
# postinstall.js runs npm run build after npm install when NODE_ENV=production
